{
  "name": "pos-cafe-server",
  "version": "1.0.0",
  "packageManager": "pnpm@10.12.1",
  "description": "POS Cafe REST API - Node.js + Express + MongoDB",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed:admin": "tsx scripts/seed-admin.js",
    "seed:employees": "tsx scripts/seed-employees.js",
    "seed:menu": "tsx scripts/seed-menu.js",
    "seed:inventory:menu": "tsx scripts/seed-inventory-from-menu.js",
    "seed:recipes:menu": "tsx scripts/seed-recipes-from-menu.js",
    "seed:expenses": "tsx scripts/seed-expenses.js",
    "seed:orders": "tsx scripts/seed-orders.js",
    "seed:invoices": "tsx scripts/seed-invoices.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "node-zklib": "^1.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "nodemon": "^3.1.0",
    "patch-package": "^8.0.1",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
